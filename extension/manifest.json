{
  "manifest_version": 3,
  "name": "白雪 Snowy - AI 浏览器助手",
  "version": "0.1.1",
  "description": "用自然语言操控网页的 AI 助手。填表、点击、提取数据、后台自动化——装上就能用，开源免费。",
  "permissions": [
    "debugger",
    "offscreen",
    "scripting",
    "tabs",
    "storage",
    "sidePanel",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://cursor.com/help*",
        "https://cursor.com/*/help*"
      ],
      "js": [
        "assets/cursor-help-page-hook.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://cursor.com/help*",
        "https://cursor.com/*/help*"
      ],
      "js": [
        "assets/cursor-help-content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/dom-snapshot-collector.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "白雪 Snowy",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "sandbox": {
    "pages": ["eval-sandbox.html"]
  },
  "minimum_chrome_version": "120"
}
